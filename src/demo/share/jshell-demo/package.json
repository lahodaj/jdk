{
	"name": "jshell-cc-demo",
	"displayName": "JShell Code Completion Demog",
	"description": "A demonstration of enhanced code completion for JShell",
	"version": "0.0.1",
	"engines": {
		"vscode": "^1.100.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
		"workspaceContains:**/*.jshell",
		"onLanguage:jshell",
		"*"
	],
	"main": "./out/extension.js",
	"contributes": {
		"languages": [
			{
				"id": "jshell",
				"aliases": [
					"JShell"
				],
				"extensions": [
					".jshell"
				]
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"pretest": "npm run compile && npm run lint",
		"lint": "eslint src",
		"test": "vscode-test",
		"build-server": "cd server && mvn clean package dependency:copy-dependencies"
	},
	"devDependencies": {
		"@types/vscode": "^1.100.0",
		"@types/mocha": "^10.0.10",
		"@types/node": "20.x",
		"@typescript-eslint/eslint-plugin": "^8.31.1",
		"@typescript-eslint/parser": "^8.31.1",
		"eslint": "^9.25.1",
		"typescript": "^5.8.3",
		"@vscode/test-cli": "^0.0.10",
		"@vscode/test-electron": "^2.5.2"
	},
	"dependencies": {
		"vscode-languageclient": "8.0.1"
	}
}